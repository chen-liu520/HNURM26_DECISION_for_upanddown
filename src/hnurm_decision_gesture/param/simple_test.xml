<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="3" main_tree_to_execute="decision">
    <BehaviorTree ID="decision">
        <ReactiveSequence>
            <GameStart/>
            <PubRobotStatus 
                pose_from_human="{pose_from_human}"
                need_supply="{need_supply}"
                is_pursue="{is_pursue}"
                is_cruise="{is_cruise}"
                is_in_upanddown_area="{is_in_upanddown_area}"
                upanddown_goal="{upanddown_goal}"
                human_goal="{human_goal}"
                supply_goal="{supply_goal}"
                pursue_goal="{pursue_goal}"
                cruise_goal="{cruise_goal}"
                current_controller="{current_controller}"/>
            <Parallel failure_threshold="2" success_threshold="2">
                <WhileDoElse>
                    <Status Status="{is_in_upanddown_area}"/>
                    <SubTree ID="upanddown_subtree" __shared_blackboard="true"/>
                    <WhileDoElse>
                        <Status Status="{pose_from_human}"/>
                        <SubTree ID="human_goal_subtree" __shared_blackboard="true"/>
                        <WhileDoElse>
                            <Status Status="{need_supply}"/>
                            <SubTree ID="supply_subtree" __shared_blackboard="true"/>
                            <WhileDoElse>
                                <Status Status="{is_pursue}"/>
                                <SubTree ID="pursuit_subtree" __shared_blackboard="true"/>
                                <WhileDoElse>
                                    <Status Status="{is_cruise}"/>
                                    <SubTree ID="cruise_subtree" __shared_blackboard="true"/>
                                    <AlwaysSuccess/>
                                </WhileDoElse>
                            </WhileDoElse>
                        </WhileDoElse>
                    </WhileDoElse>
                </WhileDoElse>
                <WhileDoElse>
                    <Status Status="{do_clear}"/>
                    <ClearEntireCostmap service_name="local_costmap/clear_entirely_local_costmap" server_timeout="1000"/>
                    <AlwaysSuccess/>
                </WhileDoElse>
            </Parallel>
        </ReactiveSequence>
    </BehaviorTree>
    
    <!-- 起伏路段导航子树 -->
    <BehaviorTree ID="upanddown_subtree">
        <PipelineSequence name="NavigateInUpAndDownArea">
            <RateController hz="50.0">
                <Sequence>
                    <ComputePathToPose goal="{upanddown_goal}" planner_id="GridBased" path="{upanddown_path}"/>
                    <TruncatePath distance="0.1" input_path="{upanddown_path}" output_path="{truncated_upanddown_path}"/>
                </Sequence>
            </RateController>
            <KeepRunningUntilFailure>
                <FollowPath controller_id="{current_controller}" path="{truncated_upanddown_path}"/>
            </KeepRunningUntilFailure>
        </PipelineSequence>
    </BehaviorTree>

    <!-- 人类目标点子树 -->
    <BehaviorTree ID="human_goal_subtree">
        <PipelineSequence name="NavigateToHumanGoal">
            <RateController hz="50.0">
                <Sequence>
                    <GoalUpdater input_goal="{human_goal}" output_goal="{updated_human_goal}">
                        <ComputePathToPose goal="{updated_human_goal}" planner_id="GridBased" path="{human_goal_path}"/>
                    </GoalUpdater>
                    <TruncatePath distance="0.1" input_path="{human_goal_path}" output_path="{truncated_human_goal_path}"/>
                </Sequence>
            </RateController>
            <KeepRunningUntilFailure>
                <FollowPath controller_id="{current_controller}" path="{truncated_human_goal_path}"/>
            </KeepRunningUntilFailure>
        </PipelineSequence>
    </BehaviorTree>

    <!-- 补给子树 -->
    <BehaviorTree ID="supply_subtree">
        <PipelineSequence name="NavigateToSupply">
            <RateController hz="50.0">
                <Sequence>
                    <GoalUpdater input_goal="{supply_goal}" output_goal="{updated_supply_goal}">
                        <ComputePathToPose goal="{updated_supply_goal}" planner_id="GridBased" path="{supply_path}"/>
                    </GoalUpdater>
                    <TruncatePath distance="0.1" input_path="{supply_path}" output_path="{truncated_supply_path}"/>
                </Sequence>
            </RateController>
            <KeepRunningUntilFailure>
                <FollowPath controller_id="FollowPath" path="{truncated_supply_path}"/>
            </KeepRunningUntilFailure>
        </PipelineSequence>
    </BehaviorTree>

    <!-- 追击子树 -->
    <BehaviorTree ID="pursuit_subtree">
        <PipelineSequence name="NavigateWithReplanning">
            <RateController hz="50.0">
                <Sequence>
                    <GoalUpdater input_goal="{pursue_goal}" output_goal="{updated_pursue_goal}">
                        <ComputePathToPose goal="{updated_pursue_goal}" planner_id="GridBased" path="{pursue_path}"/>
                    </GoalUpdater>
                    <TruncatePath distance="2.6" input_path="{pursue_path}" output_path="{truncated_pursue_path}"/>
                </Sequence>
            </RateController>
            <KeepRunningUntilFailure>
                <FollowPath controller_id="FollowPath" path="{truncated_pursue_path}"/>
            </KeepRunningUntilFailure>
        </PipelineSequence>
    </BehaviorTree>
    
    <!-- 巡航子树 -->
    <BehaviorTree ID="cruise_subtree">
        <PipelineSequence name="NavigateCruise">
            <RateController hz="50.0">
                <Sequence>
                    <GoalUpdater input_goal="{cruise_goal}" output_goal="{updated_cruise_goal}">
                        <ComputePathToPose goal="{updated_cruise_goal}" planner_id="GridBased" path="{cruise_path}"/>
                    </GoalUpdater>
                    <TruncatePath distance="0.1" input_path="{cruise_path}" output_path="{truncated_cruise_path}"/>
                </Sequence>
            </RateController>
            <KeepRunningUntilFailure>
                <FollowPath controller_id="{current_controller}" path="{truncated_cruise_path}"/>
            </KeepRunningUntilFailure>
        </PipelineSequence>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="ClearEntireCostmap">
            <input_port name="service_name">Service name</input_port>
            <input_port name="server_timeout">Server timeout</input_port>
        </Action>
        <Action ID="ComputePathToPose" editable="true">
            <input_port name="goal">Destination to plan to</input_port>
            <input_port name="planner_id">Mapped name to the planner plugin type to use</input_port>
            <output_port name="path">Path created by ComputePathToPose node</output_port>
        </Action>
        <Action ID="FollowPath" editable="true">
            <input_port name="controller_id" default="FollowPath"/>
            <input_port name="path">Path to follow</input_port>
        </Action>
        <Condition ID="GameStart" editable="true"/>
        <Decorator ID="GoalUpdater">
            <input_port name="input_goal">Original goal in</input_port>
            <output_port name="output_goal">Output goal set by subscription</output_port>
        </Decorator>
        <Control ID="PipelineSequence"/>
        <Decorator ID="RateController">
            <input_port name="hz">Rate</input_port>
        </Decorator>
        <Condition ID="Status" editable="true">
            <input_port name="Status" default="{Status}"/>
        </Condition>
        <Action ID="TruncatePath">
            <input_port name="distance">Distance before goal to truncate</input_port>
            <input_port name="input_path">Path to truncate</input_port>
            <output_port name="output_path">Truncated path to utilize</output_port>
        </Action>
        <Action ID="Wait">
            <input_port name="wait_duration">Wait time</input_port>
        </Action>
        <Action ID="PubRobotStatus" editable="true">
            <output_port name="pose_from_human" default="{pose_from_human}">人类打断标志</output_port>
            <output_port name="need_supply" default="{need_supply}">补给标志</output_port>
            <output_port name="is_pursue" default="{is_pursue}">追击标志</output_port>
            <output_port name="is_cruise" default="{is_cruise}">巡航标志</output_port>
            <output_port name="is_in_upanddown_area" default="{is_in_upanddown_area}">起伏路段标志</output_port>
            <output_port name="upanddown_goal" default="{upanddown_goal}">起伏路段目标点</output_port>
            <output_port name="human_goal" default="{human_goal}">人类目标点</output_port>
            <output_port name="supply_goal" default="{supply_goal}">补给目标点</output_port>
            <output_port name="pursue_goal" default="{pursue_goal}">追击目标点</output_port>
            <output_port name="cruise_goal" default="{cruise_goal}">巡航目标点</output_port>
            <output_port name="current_controller" default="{current_controller}">当前控制器ID</output_port>
        </Action>
    </TreeNodesModel>

</root>
